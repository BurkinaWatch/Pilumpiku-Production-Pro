# ================================================================
# Pilimpiku Production — Variables d'environnement
# ================================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# Sur Railway, configurez ces variables dans le dashboard > Variables.

# ----------------------------------------------------------------
# Base de données PostgreSQL (fournie automatiquement par Railway)
# ----------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ----------------------------------------------------------------
# Serveur
# ----------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ----------------------------------------------------------------
# Authentification (Replit OIDC)
# Requis si vous utilisez le panneau d'administration.
# Sur Railway, remplacez par votre domaine Railway.
# ----------------------------------------------------------------
REPLIT_DOMAINS=votre-app.railway.app
SESSION_SECRET=changez-moi-avec-une-longue-valeur-aleatoire-securisee

# ----------------------------------------------------------------
# Optionnel — Chemins personnalisés (Railway détecte automatiquement)
# ----------------------------------------------------------------
# MIGRATIONS_PATH=/app/lib/db/migrations
# FRONTEND_DIST_PATH=/app/artifacts/pilimpiku/dist/public
